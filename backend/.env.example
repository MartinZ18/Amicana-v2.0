# =============================================================
# DESARROLLO LOCAL — copiar a backend/.env y completar
# =============================================================

# ── Base de datos MySQL ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=gestion_facturas_amicana

# ── Seguridad JWT ────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<genera-con: python -c "import secrets; print(secrets.token_hex(32))">

# ── Seed del usuario admin (solo se usa al arrancar por primera vez) ──
ADMIN_SEED_PASSWORD=admin123

# ── Google OAuth 2.0 (login con Google) ──────────────────────────
# Crear credenciales en https://console.cloud.google.com/apis/credentials
# Tipo: OAuth client ID → Web application
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=<tu-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<tu-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# URL del frontend a la que redirigir tras callback exitoso (con ?token=...)
GOOGLE_POST_LOGIN_REDIRECT=http://localhost:8000/app/index.html

# ── n8n Chatbot (clave compartida entre FastAPI y n8n) ───────────
# Debe coincidir con la variable CHATBOT_INTERNAL_KEY en n8n Settings > Variables
CHATBOT_INTERNAL_KEY=amicana-internal
N8N_WEBHOOK_URL=http://localhost:5678/webhook/amicana-chatbot
N8N_TIMEOUT_SECONDS=30
# LLM del chatbot (Groq, gratis sin tarjeta). docker-compose se la pasa a n8n
# vía env_file; el workflow la lee con $env.GROQ_API_KEY. Obtener en console.groq.com
GROQ_API_KEY=<tu-groq-api-key>  # gsk_...

# ── MercadoPago ──────────────────────────────────────────────────
# Token de sandbox (TEST...) o producción (APP_USR-...)
# https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=<tu-mp-access-token>
# Clave secreta del webhook: MP Developers > Tu integración > Webhooks > Clave secreta
MP_WEBHOOK_SECRET=<tu-webhook-secret>

# ── CORS ─────────────────────────────────────────────────────────
# CSV de orígenes permitidos. Vacío = defaults de desarrollo (localhost).
# Producción: definir explícitamente, ej "https://app.amicana.com,https://amicana.com"
CORS_ORIGINS=

# ── URL pública de la app (ngrok local o dominio de Railway en producción) ──
# Usada por MercadoPago para back_urls y webhook notification_url
NGROK_URL=https://chaffy-gamely-ramon.ngrok-free.dev


# =============================================================
# RAILWAY — estas variables se cargan en el dashboard de Railway
# (railway.app → tu proyecto → Variables), NO en el .env del repo
# =============================================================

# ── Base de datos (Railway MySQL plugin — referencias automáticas) ──
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_USER=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
# DB_NAME=${{MySQL.MYSQLDATABASE}}

# ── URL pública de Railway (reemplaza NGROK_URL en producción) ──
# Obtener de: Railway → tu servicio FastAPI → Settings → Networking → Domain
# NGROK_URL=https://TU-DOMINIO.up.railway.app

# ── Google OAuth — actualizar en Railway dashboard Y en Google Console ──
# GOOGLE_REDIRECT_URI=https://TU-DOMINIO.up.railway.app/auth/google/callback
# GOOGLE_POST_LOGIN_REDIRECT=https://TU-DOMINIO.up.railway.app/app/index.html

# ── n8n en Railway ──────────────────────────────────────────────
# N8N_WEBHOOK_URL=https://TU-N8N.up.railway.app/webhook/amicana-chatbot

# ── CORS en Railway ─────────────────────────────────────────────
# CORS_ORIGINS=https://TU-DOMINIO.up.railway.app
